# ── Local-only MCP server config (not part of the lab) ──
.mcp.json

# ── Terraform ──
**/.terraform/*
.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.plan
*.bak
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Live tfvars (students copy *.example -> terraform.tfvars and edit).
